# Backend internal API (mcp/ never touches Supabase directly — it resolves
# a customer's mcp_token via the backend's internal API, then reads data
# through it, the same pattern ds-agent/ uses).
BACKEND_URL=http://127.0.0.1:8000
BACKEND_INTERNAL_KEY=<must-match-backend-INTERNAL_API_KEY>

# In prod (deploy-mcp.yml bootstraps all of these automatically — see that
# workflow; values already present in mcp/.env are never overwritten):
#
# Host allow-list for the SDK's DNS-rebinding protection. Must contain the
# public hostname nginx proxies from, or every request 421s.
#MCP_ALLOWED_HOSTS=api.sprntly.ai
#
# Accept the bearer token from ?token= in the connector URL, not just the
# Authorization header. Required in prod: the Settings → MCP Access UI hands
# out URLs with the token embedded (claude.ai's connector UI has no field
# for a static header).
#MCP_ALLOW_URL_TOKEN=1
