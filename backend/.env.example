ANTHROPIC_API_KEY=sk-ant-...
ALLOWED_ORIGINS=https://sprntly.ai,https://www.sprntly.ai,http://localhost:3000
ENV=development

# Demo gate (single shared password)
DEMO_PASSWORD=change-me
JWT_SECRET=replace-with-32+-random-bytes
SESSION_TTL_HOURS=720

# Cookie domain for the JWT session (parent domain so demo.sprntly.ai shares it with api.sprntly.ai)
COOKIE_DOMAIN=.sprntly.ai
