ANTHROPIC_API_KEY=sk-ant-...
ALLOWED_ORIGINS=https://sprntly.ai,https://www.sprntly.ai,http://localhost:3000
ENV=development

# Demo gate (single shared password)
DEMO_PASSWORD=change-me
JWT_SECRET=replace-with-32+-random-bytes
SESSION_TTL_HOURS=720

# Cookie domain for the JWT session (parent domain so demo.sprntly.ai shares it with api.sprntly.ai)
COOKIE_DOMAIN=.sprntly.ai

# Staff admin panel (/admin + /v1/staff) — dedicated owner-only credential,
# completely separate from normal Sprntly (Supabase) login. BOTH must be set
# or the whole staff surface is disabled: every /v1/staff route, login
# included, returns 404 (fail closed, invisible). A successful login mints a
# 12h staff JWT (aud=sprntly-staff) signed with JWT_SECRET above.
STAFF_ADMIN_ID=
# argon2id hash of the staff password (argon2-cffi ships with the backend).
# Generate one, prompting for the password without echo:
#   python -c "from argon2 import PasswordHasher; import getpass; print(PasswordHasher().hash(getpass.getpass()))"
STAFF_ADMIN_PASSWORD_HASH=

# Where uploaded dataset originals and converted markdown live. In prod this
# is set to /var/lib/sprntly/data so EC2 `git pull` deploys don't wipe uploads.
# Templates (sprntly_prd_template.md, sprntly_evidence_template.md) stay in
# the repo at TEMPLATE_DIR.
DATA_DIR=/var/lib/sprntly/data
TEMPLATE_DIR=./data
DB_PATH=/var/lib/sprntly/data/sprintly.db

# Google Drive connector — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.sprntly.ai/v1/connectors/google-drive/callback
# Google's OAuth client auto-adds openid/userinfo.* scopes (it doubles as a
# sign-in client) and may reorder openid, which trips oauthlib's scope-change
# guard at token exchange. The app sets this default in-process at startup too
# (app/main.py); kept here for visibility / explicit deploys.
OAUTHLIB_RELAX_TOKEN_SCOPE=1
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
FRONTEND_URL=https://api.sprntly.ai/demo

# Figma OAuth — https://www.figma.com/developers/apps
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_OAUTH_REDIRECT_URI=https://api.sprntly.ai/v1/connectors/figma/callback

# ClickUp OAuth — https://app.clickup.com/settings/apps (Create new app)
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
CLICKUP_OAUTH_REDIRECT_URI=https://api.sprntly.ai/v1/connectors/clickup/callback

# HubSpot OAuth — modern path: install the HubSpot CLI
# (npm install -g @hubspot/cli), run `hs project create`, copy credentials
# from the generated project. Legacy path: developers.hubspot.com → Apps →
# Create legacy app (only works on older HubSpot accounts; new accounts
# are blocked since legacy public app creation was sunset in 2026).
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_OAUTH_REDIRECT_URI=https://api.sprntly.ai/v1/connectors/hubspot/callback
# Space-separated scopes. `oauth` is the minimum; add data scopes when
# sync features need them (e.g. crm.objects.contacts.read).
HUBSPOT_SCOPES=oauth crm.objects.contacts.read
# Which OAuth API generation to use: "v3" (default, modern, RFC 7662
# introspection, 30-min access tokens) or "v1" (legacy, sunset-pending,
# 6-hour access tokens). New apps via `hs project create` use v3.
HUBSPOT_OAUTH_VERSION=v3

# Slack OAuth — https://api.slack.com/apps
# Bot Token Scopes required:
#   chat:write         — post weekly briefs to channels
#   channels:read      — list public channels
#   channels:history   — read messages from public channels
#   groups:read        — list private channels the bot belongs to
#   groups:history     — read messages from private channels
#   users:read         — resolve user IDs to display names
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_OAUTH_REDIRECT_URI=https://api.sprntly.ai/v1/connectors/slack/callback
# Slack app → Basic Information → Signing Secret. Required to verify the Events
# API webhook (app_uninstalled + app_home_opened). Empty → events endpoint 401s.
SLACK_SIGNING_SECRET=

# GitHub App — https://github.com/settings/apps (see backend/docs/CONNECTORS.md)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Literal PEM contents or single-line with \n escapes; config.py normalizes either.
GITHUB_APP_PRIVATE_KEY=
GITHUB_OAUTH_REDIRECT_URI=https://api.sprntly.ai/v1/connectors/github/callback
# python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=

# Supabase — shared project that holds cross-surface data (e.g. interest_signups
# from the marketing site). Backend writes to it in addition to the local SQLite
# DB when SUPABASE_DUAL_WRITE=true. Anon key is publishable; service-role
# bypasses RLS — keep it server-side only.
SUPABASE_URL=https://vnfnmiauoblodxmjmaqw.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DUAL_WRITE=true
# Settings → API → JWT Secret (verifies Authorization: Bearer tokens from the app)
SUPABASE_JWT_SECRET=

# Resend key for transactional email. Used in TWO places:
#   1) SUPABASE auth SMTP for invites / magic links / confirms (config.toml
#      references it as env(RESEND_API_KEY) for the local CLI stack; the DEPLOYED
#      project reads SMTP creds from Supabase Dashboard → Authentication → SMTP).
#   2) The backend's onboarding drip / nudge emails (app/drip_email.py), which
#      call the Resend HTTP API directly with this key. When unset, drip sends
#      are recorded as "skipped" (no double-send when you enable it later).
# From address is noreply@mail.sprntly.ai (domain verified in Resend). Create the
# key at resend.com → API Keys (sending permission).
RESEND_API_KEY=

# Pipeline scheduler (multi-agent orchestration)
# Set SCHEDULER_ENABLED=true to auto-run the full pipeline every N hours.
# Pipeline: connector sync → marketing agent → competitor agent → knowledge graph → brief
# Production: set to true. Local dev: false to avoid unintended background scraping.
SCHEDULER_ENABLED=true
PIPELINE_INTERVAL_HOURS=6

# Onboarding drip / nudge emails (v0 checklist 2.1).
# Recurring onboarding emails to newly-joined company members on a cadence
# (default day-1 / day-3 / day-7 after they join). Sent via Resend; tracked per
# member × step in drip_email_sends so a step never double-sends. Opt-in: the
# drip scheduler job runs only when BOTH SCHEDULER_ENABLED and
# DRIP_EMAILS_ENABLED are true.
DRIP_EMAILS_ENABLED=false
# How often the drip job runs (de-dup makes extra cycles cheap no-ops).
DRIP_INTERVAL_HOURS=6
# Global cadence as comma-separated day offsets (e.g. 1,3,7). Empty → built-in
# default. Per-company overrides in companies.notification_settings["drip"]
# (keys: enabled, cadence:[{key, day_offset, subject, body_text}]) win over this.
DRIP_CADENCE_DAYS=
# From: header for drip emails. Empty → "Sprntly <onboarding@sprntly.ai>".
DRIP_FROM_EMAIL=
# ── Onboarding welcome email ────────────────────────────────────────────────
# The instant "welcome to Sprntly, your workspace is ready" email, fired once
# when a user completes onboarding (POST /v1/onboarding/complete). Distinct
# from the drip cadence above. ON by default, but RESEND_API_KEY still gates
# the transport — with no key it's a no-op recorded as "skipped".
WELCOME_EMAIL_ENABLED=true
# From: header. Empty → "Sprntly <onboarding@mail.sprntly.ai>".
WELCOME_EMAIL_FROM=
# The "one-page guide" link in the email. Empty → "<FRONTEND_URL>/guide".
WELCOME_GUIDE_URL=
# ── Invite reminders ────────────────────────────────────────────────────────
# Day-1 / Day-3 follow-up emails to invitees who haven't accepted yet (Day 0
# fires inline at invite time). ON by default, but RESEND_API_KEY gates the
# transport and the scheduler job only runs when SCHEDULER_ENABLED is also on.
# Recorded per (invite, step) in invite_reminder_sends so a step never repeats.
INVITE_REMINDERS_ENABLED=true
INVITE_REMINDER_INTERVAL_HOURS=6
# An invite is treated as expired this many days after it was created; past
# that, no more reminders go out. Keep it AFTER the last reminder (Day 7 can
# land ~17 days out with the chained cadence + weekend shifts).
INVITE_EXPIRY_DAYS=30
# From: header for reminders. Empty → BRIEF_EMAIL_FROM (the verified sender).
INVITE_FROM_EMAIL=
# DS Agent sidecar URL (optional — leave blank to skip DS Agent stage)
DS_AGENT_URL=http://localhost:8001
