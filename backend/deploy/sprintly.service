[Unit]
Description=Sprintly FastAPI backend
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/Sprntly/backend
EnvironmentFile=/home/ec2-user/Sprntly/backend/.env
ExecStart=/home/ec2-user/Sprntly/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
