NEXT_PUBLIC_DESIGN_AGENT_ENABLED=true

# ── Sentry (browser error tracking) ──
# Leave NEXT_PUBLIC_SENTRY_DSN empty to disable Sentry entirely (local/dev). Set
# it (from the sentry.io "sprntly-web" project) to turn on client-side tracking.
# NEXT_PUBLIC_* vars are inlined at build time, so the build env must have them.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Optional: git sha / version for grouping regressions across releases.
NEXT_PUBLIC_SENTRY_RELEASE=
# Optional performance tracing (0 = off). Raise to sample transactions.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# Session Replay sampling (leave UNSET to use the code defaults below).
#   REPLAY_ON_ERROR_SAMPLE_RATE: fraction of error sessions to record (default 1.0 = always)
#   REPLAY_SAMPLE_RATE:          fraction of ALL sessions to record  (default 0.1 = 10%)
# Set BOTH to 0 to fully disable replay recording. Recordings mask all text/inputs.
NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0.1
# Source-map upload at `next build` (optional; only runs when all three are set).
# SENTRY_ORG and SENTRY_PROJECT identify the project; SENTRY_AUTH_TOKEN authorizes
# the upload — keep the token OUT of the client (it is build-only, never NEXT_PUBLIC_).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
