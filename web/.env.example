# Backend API URL. Defaults to https://api.sprntly.ai when unset (see api.ts).
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth (Project Settings → API)
# Full project URL from Supabase Dashboard → Settings → API (include https://)
NEXT_PUBLIC_SUPABASE_URL=https://vnfnmiauoblodxmjmaqw.supabase.co
# Publishable key (sb_publishable_...) or legacy anon JWT (eyJ...) — NOT sb_secret_ / service_role
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Optional: extra consumer emails allowed to sign in (comma-separated, full addresses)
# NEXT_PUBLIC_AUTH_EMAIL_ALLOWLIST=founder@gmail.com,qa@icloud.com

# Design Agent feature flag — keep at 0 throughout the build engagement (Sprntly flips after P2 ships).
NEXT_PUBLIC_DESIGN_AGENT_ENABLED=0
